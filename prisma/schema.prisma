generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Product {
  id             String      @id @default(cuid())
  code           String      @unique
  name           String
  category       String
  price          Float
  stockQuantity  Int         @default(0)
  expirationDate DateTime?
  imageUrl       String?
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  sales          Sale[]
  orderItems     OrderItem[]
}

model Sale {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  unitPrice Float
  total     Float
  createdAt DateTime @default(now())
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  customerName  String
  customerPhone String
  customerEmail String?
  notes         String?
  status        String      @default("PENDING")
  subtotal      Float
  total         Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  total     Float
}

model BakerySettings {
  id           String @id @default("default")
  name         String @default("Tutti Pane")
  description  String @default("Tradição e sabor em cada fornada")
  address      String @default("Rua das Flores, 123 - Centro")
  phone        String @default("5511999999999")
  whatsapp     String @default("5511999999999")
  latitude     Float  @default(-23.5505)
  longitude    Float  @default(-46.6333)
  openingHours String @default("Seg-Sáb: 6h às 20h | Dom: 6h às 14h")
}
