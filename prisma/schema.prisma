generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Product {
  id             String    @id @default(cuid())
  code           String    @unique
  name           String
  category       String
  price          Float
  stockQuantity  Int       @default(0)
  expirationDate DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model BakerySettings {
  id           String @id @default("default")
  name         String @default("Tutti Pane")
  description  String @default("Tradição e sabor em cada fornada")
  address      String @default("Rua das Flores, 123 - Centro")
  phone        String @default("5511999999999")
  whatsapp     String @default("5511999999999")
  latitude     Float  @default(-23.5505)
  longitude    Float  @default(-46.6333)
  openingHours String @default("Seg-Sáb: 6h às 20h | Dom: 6h às 14h")
}
